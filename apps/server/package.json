{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seeds/index.ts",
    "db:test-exercises": "tsx prisma/seeds/test-exercises.ts",
    "db:reset": "prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@atlas/shared": "workspace:*",
    "@prisma/adapter-pg": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.1.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^16.6.1",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
